{
  "name": "specmate",
  "version": "0.1.0",
  "description": "BSV (Bluespec SystemVerilog) coding assistant — knowledge base, pre-compile checker, and error reference for AI agents",
  "keywords": ["bluespec", "bsv", "bsc", "hardware", "verilog", "mcp"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alele496/bsv-specmate"
  },
  "type": "module",
  "bin": {
    "specmate": "./bin/server.mjs"
  },
  "files": [
    "AGENTS.md",
    "README.md",
    "README.en.md",
    "docs/",
    "examples/bsv/",
    "examples/bs/",
    "bin/",
    "src/"
  ],
  "scripts": {
    "start": "node bin/server.mjs",
    "db:seed": "node src/db/seed.mjs",
    "db:export": "node src/db/export.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "sql.js": "^1.12.0"
  },
  "engines": {
    "node": ">=18"
  }
}
