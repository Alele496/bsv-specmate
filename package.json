{
  "name": "bsv-specmate",
  "version": "0.1.0",
  "description": "BSV Coding Knowledge Engine — domain knowledge layer for AI agents writing Bluespec SystemVerilog",
  "keywords": [
    "bluespec",
    "bsv",
    "bsc",
    "hardware",
    "verilog",
    "mcp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alele496/bsv-specmate"
  },
  "type": "module",
  "bin": {
    "bsv-specmate": "./bin/server.mjs"
  },
  "files": [
    "AGENTS.md",
    "README.md",
    "README.en.md",
    "bin/",
    "data/",
    "docs/",
    "examples/bs/",
    "examples/bsv/",
    "examples/templates/",
    "src/"
  ],
  "scripts": {
    "start": "node bin/server.mjs",
    "db:seed": "node src/db/seed.mjs",
    "db:export": "node src/db/export.mjs",
    "test": "node --test src/db/query.test.mjs src/tools/_matcher.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "sql.js": "^1.12.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-bsv": "^0.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
