{
  "name": "bsv-specmate",
  "version": "0.1.0",
  "description": "BSV Coding Knowledge Engine — domain knowledge layer for AI agents writing Bluespec SystemVerilog",
  "keywords": [
    "bluespec",
    "bsv",
    "bsc",
    "hardware",
    "verilog",
    "mcp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alele496/bsv-specmate"
  },
  "type": "module",
  "bin": {
    "specmate": "./bin/cli.mjs",
    "bsv-specmate": "./bin/server.mjs"
  },
  "files": [
    "AGENTS.md",
    "README.md",
    "README.en.md",
    "bin/",
    "src/",
    "data/knowledge.db",
    "docs/errors/",
    "docs/reference/",
    "docs/traps/",
    "docs/BSV-STYLE.md",
    "docs/architecture.md",
    "docs/getting-started.md",
    "docs/agent-integration.md",
    "docs/checklist.md"
  ],
  "scripts": {
    "start": "node bin/server.mjs",
    "db:seed": "node src/db/seed.mjs",
    "db:export": "node src/db/export.mjs",
    "test": "node --test src/db/query.test.mjs src/tools/_matcher.test.mjs src/tools/ast_query.test.mjs test/knowledge-validation.test.mjs && node test/fixtures/run-fixtures.mjs && node scripts/smoke-test.mjs",
    "test:unit": "node --test src/db/query.test.mjs src/tools/_matcher.test.mjs src/tools/ast_query.test.mjs",
    "test:knowledge": "node --test test/knowledge-validation.test.mjs",
    "test:fixtures": "node test/fixtures/run-fixtures.mjs",
    "test:smoke": "node scripts/smoke-test.mjs",
    "health-check": "node scripts/health-check.mjs",
    "knowledge:snapshot": "node src/tools/knowledge_snapshot.mjs",
    "knowledge:validate": "node --test test/knowledge-validation.test.mjs",
    "verify-traps": "node scripts/verify-traps.mjs",
    "prepare": "husky",
    "prepublishOnly": "npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "sql.js": "^1.12.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-bsv": "^0.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
